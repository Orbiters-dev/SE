  <data key="d5">1775314015</data>
  <data key="d6"></data>
</node>
<node id="CAC">
  <data key="d0">CAC</data>
  <data key="d1">organization</data>
  <data key="d2">Customer Acquisition Cost (CAC) is a monthly KPI indicating the cost associated with acquiring new customers.&lt;SEP&gt;CAC is an entity associated with using inverse logic in performance metrics, where lower values indicate better performance.</data>
  <data key="d3">chunk-565e3686182be6732f4eb713f7aefecc&lt;SEP&gt;chunk-a4d5d088a0554b7df2fdd7bc88d931e6</data>
