<node id="WARNING">
  <data key="d0">WARNING</data>
  <data key="d1">concept</data>
  <data key="d2">WARNING is a status used in the audit scoring that represents a partial failure of a check, earning 50% of the full points assigned.</data>
  <data key="d3">chunk-7f58d260c5bbcf37fe9a49d8bfd44441</data>
