  <data key="d0">Audience-Creative Mismatch</data>
  <data key="d1">concept</data>
  <data key="d2">Audience-Creative Mismatch refers to a scenario where the ad's content does not resonate with its intended audience.</data>
  <data key="d3">chunk-d9325aa8b09d601b506d1bfb8a0fdbf1</data>
  <data key="d4">skill__meta-ads-agent__ref__ad_relevance_diagnostics.md</data>
  <data key="d5">1775314276</data>
