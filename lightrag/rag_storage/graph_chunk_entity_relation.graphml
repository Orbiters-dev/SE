<node id="D2C">
  <data key="d0">D2C</data>
  <data key="d1">concept</data>
  <data key="d2">D2C stands for Direct-to-Consumer, a sales model where goods are sold directly to consumers without intermediaries.&lt;SEP&gt;D2C stands for Direct-to-Consumer, indicating a sales model that includes various online channels for selling products directly to consumers.</data>
  <data key="d3">chunk-2e216433e87e27df18023b92896cdd9c&lt;SEP&gt;chunk-8964ad7b95da832e458de5ac218c90ab</data>
