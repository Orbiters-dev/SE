  <data key="d5">1775314418</data>
  <data key="d6"></data>
</node>
<node id="Bid">
  <data key="d0">Bid</data>
  <data key="d1">concept</data>
  <data key="d2">Bid represents the amount an advertiser is willing to pay for a desired ad outcome.</data>
  <data key="d3">chunk-47b40c2d8c8650905a9f57434cf095c4</data>
  <data key="d4">skill__meta-ads-agent__ref__ad_auctions.md</data>
  <data key="d5">1775314274</data>
  <data key="d6"></data>
</node>
<node id="Estimated Action Rates">
  <data key="d0">Estimated Action Rates</data>
  <data key="d1">concept</data>
  <data key="d2">Estimated Action Rates indicate the predicted probability that a user will engage with or convert from an ad.</data>
  <data key="d3">chunk-47b40c2d8c8650905a9f57434cf095c4</data>
  <data key="d4">skill__meta-ads-agent__ref__ad_auctions.md</data>
  <data key="d5">1775314274</data>
  <data key="d6"></data>
</node>
<node id="Ad Quality">
  <data key="d0">Ad Quality</data>
  <data key="d1">concept</data>
  <data key="d2">Ad Quality encompasses user feedback and assessments that influence the success of an advertisement in the auction.&lt;SEP&gt;Ad Quality encompasses user feedback and assessments of quality attributes, influencing the Total Value in the ad auction process.</data>
  <data key="d3">chunk-47b40c2d8c8650905a9f57434cf095c4&lt;SEP&gt;chunk-b70dcbf46893fec74c116376cce3d4cf</data>
