  <data key="d0">Phase 2: PLAN</data>
  <data key="d1">concept</data>
  <data key="d2">Phase 2: PLAN involves defining the sprint's scope and assigning roles and responsibilities.</data>
  <data key="d3">chunk-5f0db10cb6ff502d03b900d2bdc7f8d9</data>
  <data key="d4">skill__제갈량.md</data>
  <data key="d5">1775315048</data>
  <data key="d6"></data>
</node>
<node id="Phase 3: EXECUTE">
