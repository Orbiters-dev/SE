</node>
<node id="Channel ROAS">
  <data key="d0">Channel ROAS</data>
  <data key="d1">data</data>
  <data key="d2">Channel ROAS (Return on Advertising Spend) indicates the effectiveness of advertising campaigns across different platforms based on revenue generated.&lt;SEP&gt;Channel ROAS (Return on Ad Spend) is a metric used to measure the effectiveness of advertising campaigns across different channels.</data>
  <data key="d3">chunk-49ece9a987ad279e3e4a53aaf6e064e0&lt;SEP&gt;chunk-ddbf21ec7f47d630ad746086b6682fc9</data>
