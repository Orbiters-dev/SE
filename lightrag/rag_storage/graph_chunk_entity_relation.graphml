  <data key="d5">1775314419</data>
  <data key="d6"></data>
</node>
<node id="User Value">
  <data key="d0">User Value</data>
  <data key="d1">concept</data>
  <data key="d2">User Value pertains to the benefit that an ad provides to users, which can influence its performance in auctions.</data>
  <data key="d3">chunk-47b40c2d8c8650905a9f57434cf095c4</data>
  <data key="d4">skill__meta-ads-agent__ref__ad_auctions.md</data>
  <data key="d5">1775314274</data>
  <data key="d6"></data>
