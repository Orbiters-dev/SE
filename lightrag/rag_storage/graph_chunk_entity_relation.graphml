<node id="UX/디자인">
  <data key="d0">UX/디자인</data>
  <data key="d1">concept</data>
  <data key="d2">UX/디자인은 사용자 관점에서의 직관성 및 디자인을 평가하는 기준이다.</data>
  <data key="d3">chunk-5122ca9d79dd5ae57c7c99500db14cd0</data>
