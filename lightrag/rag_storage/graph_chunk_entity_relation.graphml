<node id="Total Ad Budget">
  <data key="d0">Total Ad Budget</data>
  <data key="d1">data</data>
  <data key="d2">Total Ad Budget is the overall budget allocated for advertising across different platforms like Amazon, Google, and Meta.</data>
  <data key="d3">chunk-49ece9a987ad279e3e4a53aaf6e064e0</data>
  <data key="d4">skill__amazon-ppc-agent__ref__cross-platform-analysis.md</data>
