  <data key="d0">Phase 1: THINK</data>
  <data key="d1">concept</data>
  <data key="d2">Phase 1: THINK focuses on identifying risks and dependency relationships within ongoing projects.</data>
  <data key="d3">chunk-5f0db10cb6ff502d03b900d2bdc7f8d9</data>
  <data key="d4">skill__제갈량.md</data>
  <data key="d5">1775315047</data>
