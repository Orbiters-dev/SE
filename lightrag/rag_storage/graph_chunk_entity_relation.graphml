<node id="Impressions">
  <data key="d0">Impressions</data>
  <data key="d1">metric</data>
  <data key="d2">Impressions indicate the number of times ads are displayed to users within the Amazon PPC framework.&lt;SEP&gt;Impressions is a standardized metric name representing the number of times an ad is displayed.</data>
  <data key="d3">chunk-deb6c473ba9d1e163a8254ec0cc102e8&lt;SEP&gt;chunk-26c52c954d001b7f51d6f34c24f651ad</data>
