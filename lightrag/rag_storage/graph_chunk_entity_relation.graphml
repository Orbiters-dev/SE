  <data key="d5">1775314133</data>
  <data key="d6"></data>
</node>
<node id="Gross Profit">
  <data key="d0">Gross Profit</data>
  <data key="d1">concept</data>
  <data key="d2">Gross Profit is calculated by subtracting COGS from Net Revenue, indicating the efficiency of production.&lt;SEP&gt;Gross Profit is the financial gain calculated by subtracting COGS from Net Revenue.</data>
  <data key="d3">chunk-d5de8e1dcf9a61dbf421e8d14c5dfb81&lt;SEP&gt;chunk-7d7127bfda8dc54bd1f2b53807d426a2</data>
