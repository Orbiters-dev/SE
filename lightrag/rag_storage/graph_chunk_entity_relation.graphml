  <data key="d0">Phase 0: SCAN</data>
  <data key="d1">concept</data>
  <data key="d2">Phase 0: SCAN is the initial phase where the current status of agents and ongoing tasks is assessed.</data>
  <data key="d3">chunk-5f0db10cb6ff502d03b900d2bdc7f8d9</data>
  <data key="d4">skill__제갈량.md</data>
  <data key="d5">1775315047</data>
  <data key="d6"></data>
</node>
